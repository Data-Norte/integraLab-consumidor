                  "pm.test('status 200', function () { pm.response.to.have.status(200); });",
                  "const body = pm.response.json();",
                  "pm.test('api online', function () {",
                  "  pm.expect(body.status).to.eql('ok');",
                  "  pm.expect(body.service).to.eql('integralab-api');",
                  "});"
                ]
              }
            }
          ],
          "request": {
